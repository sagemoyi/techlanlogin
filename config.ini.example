[login]
# 认证页面地址
url = http://10.50.255.11/a79.htm?wlanacname=Huawei
# 学号
username = 你的学号
# 密码
password = 你的密码
# 运营商: @cmcc=移动  @telecom=电信  @unicom=联通
isp = @cmcc

[settings]
# 无头模式: true=后台运行(不弹窗)  false=显示浏览器窗口
headless = true
# 页面元素等待超时(秒)
timeout = 10
# 失败重试次数
retry_count = 3
# 重试间隔(秒)
retry_delay = 5
# 开机延迟(秒) — 等待网卡就绪，开机自启时建议设为 10~15
startup_delay = 10
